{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"mac": "2.2081",
		"android": "2.2081",
		"ios": "2.2081"
	},
	"id": "km7dev.platformerjoystick",
	"name": "Platformer Joystick",
	"version": "v1.1.0",
	"developer": "km7dev",
    "early-load": true,
	"load-priority": -309,
	"description": "Adds a joystick to platformer mode.",
	"dependencies": {
		"geode.node-ids": ">=1.22.0",
		"alphalaneous.level-storage-api": ">=1.0.2",
		"alk.better-touch-prio":  ">=1.0.17",
		"geode.devtools": {
			"version": ">=1.14.0",
			"required": false
		}
	},
	"resources": {
		"sprites": [
			"res/*.png"
		]
	},
    "links": {
        "source": "https://github.com/kingminer7/platformerjoystick"
    },
    "tags": [
        "editor",
        "enhancement",
        "gameplay"
    ],
	"settings": {
		"up-bind": {
			"type": "keybind",
			"name": "Up Keybind",
			"default": ["W", "Controller_LTHUMBSTICK_UP"],
			"priority": -100,
			"category":"gameplay"
		},
		"down-bind": {
			"type": "keybind",
			"name": "Down Keybind",
			"default": ["S", "Controller_LTHUMBSTICK_DOWN"],
			"priority":  -100,
			"category": "gameplay"
		},
		"left-bind": {
			"type": "keybind",
			"name": "Left Keybind",
			"default": ["A", "Controller_LTHUMBSTICK_LEFT"],
			"priority":  -100,
			"category": "gameplay"
		},
		"right-bind": {
			"type": "keybind",
			"name": "Right Keybind",
			"default": ["D", "Controller_LTHUMBSTICK_RIGHT"],
			"priority":  -100,
			"category": "gameplay"
		}
	}
}
